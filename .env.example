# TabIntelligence Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql://emi:emi_dev@localhost:5432/emi

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# S3/MinIO Storage Configuration
# ============================================================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=financial-models
S3_REGION=us-east-1

# SSL Verification for S3 connections
# SECURITY: Set to true in production to protect against MITM attacks
# Only set to false for local MinIO development with self-signed certificates
S3_VERIFY_SSL=false  # Development only - MUST be true in production

# ============================================================================
# Anthropic API Configuration (REQUIRED)
# ============================================================================
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ============================================================================
# Application Configuration
# ============================================================================
APP_NAME=TabIntelligence
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
# LOG_FORMAT: "plain" for development, "json" for production (machine-parseable)
LOG_FORMAT=plain

# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
# CORS_ORIGINS: Restrict to trusted domains for security
# Development example:
CORS_ORIGINS=["http://localhost:3000"]
# Production example (uncomment and modify):
# CORS_ORIGINS=["http://localhost:3000","https://app.tabintelligence.com"]

# ============================================================================
# Extraction Configuration
# ============================================================================
# Maximum file upload size in MB
MAX_FILE_SIZE_MB=50

# Maximum time for extraction in seconds
EXTRACTION_TIMEOUT_SECONDS=300

# Maximum retries for Claude API calls
CLAUDE_MAX_RETRIES=3

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Minimum quality grade — jobs at or below are flagged NEEDS_REVIEW
# One of: A, B, C, D, F
QUALITY_GATE_MIN_GRADE=F

# ============================================================================
# Development/Production Settings
# ============================================================================
# For production, set:
# DEBUG=false
# LOG_LEVEL=WARNING

# For development, set:
# DEBUG=true
# LOG_LEVEL=DEBUG
