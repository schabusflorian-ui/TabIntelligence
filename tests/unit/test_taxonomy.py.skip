@pytest.mark.asyncio
class TestTaxonomyManager:
    """Test cases for TaxonomyManager class."""

    async def test_get_all(self, db_session, sample_taxonomy):
        """Test retrieving all taxonomy items."""
        manager = TaxonomyManager()
        items = await manager.get_all(db_session)

        assert len(items) == 10
        assert all(isinstance(item, Taxonomy) for item in items)

        # Verify sorting by category, then canonical_name
        categories = [item.category for item in items]
        # Should be grouped by category
        assert categories == sorted(categories)

    async def test_get_by_category(self, db_session, sample_taxonomy):
        """Test filtering taxonomy by category."""
        manager = TaxonomyManager()

        # Test income statement category
        income_items = await manager.get_by_category(db_session, "income_statement")
        assert len(income_items) == 4
        assert all(item.category == "income_statement" for item in income_items)
        assert any(item.canonical_name == "revenue" for item in income_items)

        # Test balance sheet category
        bs_items = await manager.get_by_category(db_session, "balance_sheet")
        assert len(bs_items) == 3
        assert all(item.category == "balance_sheet" for item in bs_items)

        # Test cash flow category
        cf_items = await manager.get_by_category(db_session, "cash_flow")
        assert len(cf_items) == 2

        # Test debt schedule category
        debt_items = await manager.get_by_category(db_session, "debt_schedule")
        assert len(debt_items) == 1

        # Test non-existent category
        empty_items = await manager.get_by_category(db_session, "nonexistent")
        assert len(empty_items) == 0

    async def test_search_by_canonical_name(self, db_session, sample_taxonomy):
        """Test searching taxonomy by canonical name."""
        manager = TaxonomyManager()

        results = await manager.search(db_session, "revenue")
        assert len(results) >= 1
        assert any(item.canonical_name == "revenue" for item in results)

    async def test_search_by_alias(self, db_session, sample_taxonomy):
        """Test searching taxonomy by alias."""
        manager = TaxonomyManager()

        # Search for "Sales" - should find "revenue"
        results = await manager.search(db_session, "Sales")
        assert len(results) >= 1
        assert any(item.canonical_name == "revenue" for item in results)

        # Search for "COGS" - should find "cogs"
        results = await manager.search(db_session, "COGS")
        assert len(results) >= 1
        assert any(item.canonical_name == "cogs" for item in results)

    async def test_search_case_insensitive(self, db_session, sample_taxonomy):
        """Test that search is case-insensitive."""
        manager = TaxonomyManager()

        # Try different cases
        results_lower = await manager.search(db_session, "sales")
        results_upper = await manager.search(db_session, "SALES")
        results_mixed = await manager.search(db_session, "Sales")

        # All should return same results
        assert len(results_lower) == len(results_upper) == len(results_mixed)

    async def test_search_partial_match(self, db_session, sample_taxonomy):
        """Test searching with partial matches."""
        manager = TaxonomyManager()

        # Search for "debt" - should find "total_debt"
        results = await manager.search(db_session, "debt")
        assert len(results) >= 1
        assert any("debt" in item.canonical_name.lower() for item in results)

        # Search for "cash" - should find "cash" and "cfo"
        results = await manager.search(db_session, "cash")
        assert len(results) >= 1

    async def test_get_by_canonical_name(self, db_session, sample_taxonomy):
        """Test getting specific item by canonical name."""
        manager = TaxonomyManager()

        # Test existing item
        revenue = await manager.get_by_canonical_name(db_session, "revenue")
        assert revenue is not None
        assert revenue.canonical_name == "revenue"
        assert revenue.display_name == "Revenue"
        assert "Sales" in revenue.aliases

        # Test non-existent item
        nonexistent = await manager.get_by_canonical_name(db_session, "nonexistent")
        assert nonexistent is None

    async def test_get_by_canonical_names_batch(self, db_session, sample_taxonomy):
        """Test batch lookup of multiple items."""
        manager = TaxonomyManager()

        items = await manager.get_by_canonical_names(
            db_session, ["revenue", "cogs", "gross_profit", "nonexistent"]
        )

        assert len(items) == 3  # "nonexistent" won't be found
        canonical_names = {item.canonical_name for item in items}
        assert canonical_names == {"revenue", "cogs", "gross_profit"}

    async def test_format_for_prompt_all_categories(self, db_session, sample_taxonomy):
        """Test formatting all taxonomy for Claude prompt."""
        manager = TaxonomyManager()

        prompt_text = await manager.format_for_prompt(db_session)

        assert isinstance(prompt_text, str)
        assert len(prompt_text) > 0

        # Should contain category headers
        assert "Income Statement:" in prompt_text
        assert "Balance Sheet:" in prompt_text
        assert "Cash Flow:" in prompt_text

        # Should contain canonical names
        assert "revenue" in prompt_text
        assert "cogs" in prompt_text
        assert "cash" in prompt_text
        assert "cfo" in prompt_text

        # Should have multiple lines (one per category)
        lines = prompt_text.strip().split("\n")
        assert len(lines) >= 3  # At least 3 categories

    async def test_format_for_prompt_single_category(self, db_session, sample_taxonomy):
        """Test formatting single category for prompt."""
        manager = TaxonomyManager()

        prompt_text = await manager.format_for_prompt(db_session, "income_statement")

        assert isinstance(prompt_text, str)
        assert "Income Statement:" in prompt_text
        assert "revenue" in prompt_text
        assert "cogs" in prompt_text

        # Should NOT contain other categories
        assert "Balance Sheet:" not in prompt_text
        assert "Cash Flow:" not in prompt_text

    async def test_get_hierarchy(self, db_session, sample_taxonomy):
        """Test getting hierarchical taxonomy structure."""
        manager = TaxonomyManager()

        hierarchy = await manager.get_hierarchy(db_session)

        assert isinstance(hierarchy, dict)
        assert len(hierarchy) > 0

        # Check top-level items exist (no parent)
        assert "revenue" in hierarchy
        assert "cogs" in hierarchy
        assert "total_assets" in hierarchy

        # Check children are attached
        revenue_data = hierarchy["revenue"]
        assert "item" in revenue_data
        assert "children" in revenue_data
        assert revenue_data["item"].canonical_name == "revenue"

        # product_revenue should be child of revenue
        children_names = [child.canonical_name for child in revenue_data["children"]]
        assert "product_revenue" in children_names

    async def test_get_hierarchy_by_category(self, db_session, sample_taxonomy):
        """Test getting hierarchy for specific category."""
        manager = TaxonomyManager()

        hierarchy = await manager.get_hierarchy(db_session, "income_statement")

        # Should only have income statement items
        all_items = []
        for data in hierarchy.values():
            all_items.append(data["item"])
            all_items.extend(data["children"])

        assert all(item.category == "income_statement" for item in all_items)

    async def test_get_statistics(self, db_session, sample_taxonomy):
        """Test getting taxonomy statistics."""
        manager = TaxonomyManager()

        stats = await manager.get_statistics(db_session)

        assert isinstance(stats, dict)
        assert "total_items" in stats
        assert "categories" in stats

        assert stats["total_items"] == 10

        # Check category counts
        categories = stats["categories"]
        assert categories["income_statement"] == 4
        assert categories["balance_sheet"] == 3
        assert categories["cash_flow"] == 2
        assert categories["debt_schedule"] == 1

    async def test_load_taxonomy_for_stage3(self, db_session, sample_taxonomy):
        """Test convenience function for Stage 3 mapping."""
        taxonomy_text = await load_taxonomy_for_stage3(db_session)

        assert isinstance(taxonomy_text, str)
        assert len(taxonomy_text) > 0

        # Should be formatted for prompt
        assert "Income Statement:" in taxonomy_text
        assert "revenue" in taxonomy_text
        assert "cogs" in taxonomy_text

    async def test_typical_sign_values(self, db_session, sample_taxonomy):
        """Test that typical_sign values are correctly set."""
        manager = TaxonomyManager()

        revenue = await manager.get_by_canonical_name(db_session, "revenue")
        assert revenue.typical_sign == "positive"

        cogs = await manager.get_by_canonical_name(db_session, "cogs")
        assert cogs.typical_sign == "negative"

    async def test_aliases_stored_as_array(self, db_session, sample_taxonomy):
        """Test that aliases are stored and retrieved as arrays."""
        manager = TaxonomyManager()

        revenue = await manager.get_by_canonical_name(db_session, "revenue")
        assert isinstance(revenue.aliases, list)
        assert len(revenue.aliases) > 0
        assert "Sales" in revenue.aliases

    async def test_no_duplicate_canonical_names(self, db_session, sample_taxonomy):
        """Test that canonical names are unique."""
        manager = TaxonomyManager()

        all_items = await manager.get_all(db_session)
        canonical_names = [item.canonical_name for item in all_items]

        # Check for duplicates
        assert len(canonical_names) == len(set(canonical_names))


@pytest.mark.asyncio
class TestTaxonomyIntegration:
    """Integration tests for taxonomy system."""

    async def test_empty_database(self, db_session):
        """Test behavior with empty database."""
        manager = TaxonomyManager()

        items = await manager.get_all(db_session)
        assert items == []

        results = await manager.search(db_session, "revenue")
        assert results == []

        item = await manager.get_by_canonical_name(db_session, "revenue")
        assert item is None

    async def test_search_with_no_matches(self, db_session, sample_taxonomy):
        """Test search with query that matches nothing."""
        manager = TaxonomyManager()

        results = await manager.search(db_session, "xyznonexistent")
        assert results == []

    async def test_parent_child_relationship(self, db_session, sample_taxonomy):
        """Test parent-child relationships are correct."""
        manager = TaxonomyManager()

        # product_revenue has parent revenue
        product_revenue = await manager.get_by_canonical_name(db_session, "product_revenue")
        assert product_revenue.parent_canonical == "revenue"

        # revenue has no parent
        revenue = await manager.get_by_canonical_name(db_session, "revenue")
        assert revenue.parent_canonical is None

        # cash has parent current_assets
        cash = await manager.get_by_canonical_name(db_session, "cash")
        assert cash.parent_canonical == "current_assets"

    async def test_prompt_format_consistency(self, db_session, sample_taxonomy):
        """Test that prompt formatting is consistent across calls."""
        manager = TaxonomyManager()

        # Call multiple times
        prompt1 = await manager.format_for_prompt(db_session)
        prompt2 = await manager.format_for_prompt(db_session)

        assert prompt1 == prompt2

    async def test_statistics_sum_to_total(self, db_session, sample_taxonomy):
        """Test that category counts sum to total items."""
        manager = TaxonomyManager()

        stats = await manager.get_statistics(db_session)

        category_sum = sum(stats["categories"].values())
        assert category_sum == stats["total_items"]


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
