%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#3b82f6', 'primaryTextColor': '#fff', 'primaryBorderColor': '#1d4ed8', 'lineColor': '#64748b', 'fontSize': '10px'}}}%%

flowchart TB
    subgraph PM["🎯 PRODUCT MANAGER"]
        PMR["Oversight & Coordination<br/>• Quality Gates<br/>• Existential Tracking<br/>• Cost Monitoring"]
    end

    subgraph FOUNDATION["FOUNDATION (Weeks 1-3)"]
        A1["Agent 1<br/>Database<br/>━━━━━━━━━━<br/>Schema<br/>Entity Patterns<br/>Taxonomy"]
        A2["Agent 2<br/>API & Infra<br/>━━━━━━━━━━<br/>FastAPI, S3<br/>Auth, Jobs"]
    end

    subgraph EXTRACTION["GUIDED EXTRACTION ENGINE (Weeks 4-8)"]
        A3["Agent 3<br/>Orchestrator<br/>━━━━━━━━━━<br/>openpyxl, formulas<br/>networkx, anthropic"]
        A4["Agent 4<br/>Guidelines<br/>━━━━━━━━━━<br/>Prompts<br/>Taxonomy<br/>Compression"]
        A5["Agent 5<br/>Validator<br/>━━━━━━━━━━<br/>Deterministic<br/>+ Claude"]
        A6["Agent 6<br/>Lineage<br/>⚠️ EXISTENTIAL<br/>━━━━━━━━━━<br/>networkx graphs"]
        A7["Agent 7<br/>Calibrator<br/>━━━━━━━━━━<br/>ECE < 0.05"]
    end

    subgraph CLAUDE["☁️ CLAUDE API"]
        CL["Claude Sonnet<br/>━━━━━━━━━━<br/>Parse, Triage<br/>Structure, Map<br/>Verify"]
    end

    subgraph UI["USER INTERFACE (Weeks 9-12)"]
        A8["Agent 8<br/>Excel Add-in<br/>⚠️ EXISTENTIAL<br/>━━━━━━━━━━<br/>Office.js<br/>React"]
        A9["Agent 9<br/>Dashboard<br/>━━━━━━━━━━<br/>Review Queue<br/>Corrections"]
    end

    %% Dependencies
    PM --> FOUNDATION
    PM --> EXTRACTION
    PM --> UI

    A1 --> A2
    A1 --> A3
    A1 --> A6

    A2 --> A3
    A2 --> A8
    A2 --> A9

    A3 --> A4
    A3 --> CL
    A4 --> A3
    CL --> A3

    A3 --> A5
    A5 --> A6
    A5 --> A7

    A6 --> A8
    A6 --> A9

    A9 --> A4

    %% Styling
    classDef pm fill:#dc2626,stroke:#b91c1c,color:#fff
    classDef foundation fill:#3b82f6,stroke:#1d4ed8,color:#fff
    classDef extraction fill:#10b981,stroke:#059669,color:#fff
    classDef existential fill:#f59e0b,stroke:#d97706,color:#000,stroke-width:3px
    classDef claude fill:#8b5cf6,stroke:#6d28d9,color:#fff
    classDef ui fill:#ec4899,stroke:#be185d,color:#fff

    class PMR pm
    class A1,A2 foundation
    class A3,A4,A5,A7 extraction
    class A6,A8 existential
    class CL claude
    class A9 ui
